# ===================================================
# كلافو — متغيرات البيئة المطلوبة
# انسخ هذا الملف إلى .env وعبّئ القيم الحقيقية
# ===================================================

# توكن بوت تيليغرام (من @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# مفتاح وعنوان أولاما API
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_API_URL=https://ollama.com

# اسم النموذج المستخدم
MODEL_NAME=llama3

# مستودع GitHub للمزامنة التلقائية (مثال: username/repo-name)
GITHUB_REPO=your_github_username/your_repo_name
# ملاحظة: GITHUB_TOKEN يُضاف في Replit Secrets وليس هنا
